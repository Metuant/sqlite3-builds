+__attribute__((visibility("hidden"))) extern void auto_extension_optimize_before_close(sqlite3 *db);
+
+typedef struct auto_extension_progress_snapshot {
+  unsigned nProgressOps;
+  int (*xProgress)(void*);
+  void *pProgressArg;
+} auto_extension_progress_snapshot;
+
+typedef struct auto_extension_error_snapshot {
+  int errCode;
+  int errByteOffset;
+  sqlite3_value *pErr;
+} auto_extension_error_snapshot;
+
+__attribute__((visibility("hidden"))) void
+auto_extension_progress_handler_push(sqlite3 *db, int nOps,
+                                     int (*xProgress)(void*), void *pArg,
+                                     auto_extension_progress_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  snapshot->nProgressOps = db->nProgressOps;
+  snapshot->xProgress = db->xProgress;
+  snapshot->pProgressArg = db->pProgressArg;
+  db->xProgress = xProgress;
+  db->nProgressOps = (unsigned)nOps;
+  db->pProgressArg = pArg;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_progress_handler_pop(sqlite3 *db,
+                                    const auto_extension_progress_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  db->nProgressOps = snapshot->nProgressOps;
+  db->xProgress = snapshot->xProgress;
+  db->pProgressArg = snapshot->pProgressArg;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) int
+auto_extension_error_state_push(sqlite3 *db,
+                                auto_extension_error_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  snapshot->errCode = db->errCode;
+  snapshot->errByteOffset = db->errByteOffset;
+  snapshot->pErr = sqlite3_value_dup(db->pErr);
+  if( db->pErr && !snapshot->pErr ){
+    sqlite3_mutex_leave(db->mutex);
+    return SQLITE_NOMEM;
+  }
+  sqlite3_mutex_leave(db->mutex);
+  return SQLITE_OK;
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_error_state_pop(sqlite3 *db,
+                               auto_extension_error_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  db->errCode = snapshot->errCode;
+  db->errByteOffset = snapshot->errByteOffset;
+  if( snapshot->pErr ){
+    if( db->pErr || (db->pErr = sqlite3ValueNew(db))!=0 ){
+      (void)sqlite3VdbeMemCopy((Mem*)db->pErr, (Mem*)snapshot->pErr);
+    }
+    sqlite3_value_free(snapshot->pErr);
+    snapshot->pErr = 0;
+  }else if( db->pErr ){
+    sqlite3ValueSetNull(db->pErr);
+  }
+  sqlite3_mutex_leave(db->mutex);
+}
 
