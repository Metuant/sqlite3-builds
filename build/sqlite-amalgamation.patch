+static int sqliteDefaultBusyCallback(void*, int);
+
+__attribute__((visibility("hidden"))) void
+auto_extension_progress_handler_push(sqlite3 *db, int nOps,
+                                     int (*xProgress)(void*), void *pArg,
+                                     auto_extension_progress_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  snapshot->nProgressOps = db->nProgressOps;
+  snapshot->xProgress = db->xProgress;
+  snapshot->pProgressArg = db->pProgressArg;
+  db->xProgress = xProgress;
+  db->nProgressOps = (unsigned)nOps;
+  db->pProgressArg = pArg;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_progress_handler_pop(sqlite3 *db,
+                                    const auto_extension_progress_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  db->nProgressOps = snapshot->nProgressOps;
+  db->xProgress = snapshot->xProgress;
+  db->pProgressArg = snapshot->pProgressArg;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_progress_handler_clear(sqlite3 *db){
+  sqlite3_mutex_enter(db->mutex);
+  db->nProgressOps = 0;
+  db->xProgress = 0;
+  db->pProgressArg = 0;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_busy_handler_push(sqlite3 *db, int ms,
+                                 auto_extension_busy_handler_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  snapshot->xBusyHandler = db->busyHandler.xBusyHandler;
+  snapshot->pBusyArg = db->busyHandler.pBusyArg;
+  snapshot->nBusy = db->busyHandler.nBusy;
+  snapshot->busyTimeout = db->busyTimeout;
+#ifdef SQLITE_ENABLE_SETLK_TIMEOUT
+  snapshot->setlkTimeout = db->setlkTimeout;
+#endif
+  if( ms>0 ){
+    db->busyHandler.xBusyHandler = (int(*)(void*,int))sqliteDefaultBusyCallback;
+    db->busyHandler.pBusyArg = (void*)db;
+    db->busyHandler.nBusy = 0;
+    db->busyTimeout = ms;
+#ifdef SQLITE_ENABLE_SETLK_TIMEOUT
+    db->setlkTimeout = ms;
+#endif
+  }else{
+    db->busyHandler.xBusyHandler = 0;
+    db->busyHandler.pBusyArg = 0;
+    db->busyHandler.nBusy = 0;
+    db->busyTimeout = 0;
+#ifdef SQLITE_ENABLE_SETLK_TIMEOUT
+    db->setlkTimeout = 0;
+#endif
+  }
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_busy_handler_pop(sqlite3 *db,
+                                const auto_extension_busy_handler_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  db->busyHandler.xBusyHandler = snapshot->xBusyHandler;
+  db->busyHandler.pBusyArg = snapshot->pBusyArg;
+  db->busyHandler.nBusy = snapshot->nBusy;
+  db->busyTimeout = snapshot->busyTimeout;
+#ifdef SQLITE_ENABLE_SETLK_TIMEOUT
+  db->setlkTimeout = snapshot->setlkTimeout;
+#endif
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_change_counter_push(sqlite3 *db,
+                                   auto_extension_change_counter_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  snapshot->nChange = db->nChange;
+  snapshot->nTotalChange = db->nTotalChange;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_change_counter_pop(sqlite3 *db,
+                                  const auto_extension_change_counter_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  db->nChange = snapshot->nChange;
+  db->nTotalChange = snapshot->nTotalChange;
+  sqlite3_mutex_leave(db->mutex);
+}
+
+__attribute__((visibility("hidden"))) int
+auto_extension_error_state_push(sqlite3 *db,
+                                auto_extension_error_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  snapshot->errCode = db->errCode;
+  snapshot->errByteOffset = db->errByteOffset;
+  snapshot->pErr = sqlite3_value_dup(db->pErr);
+  if( db->pErr && !snapshot->pErr ){
+    sqlite3_mutex_leave(db->mutex);
+    return SQLITE_NOMEM;
+  }
+  sqlite3_mutex_leave(db->mutex);
+  return SQLITE_OK;
+}
+
+__attribute__((visibility("hidden"))) void
+auto_extension_error_state_pop(sqlite3 *db,
+                               auto_extension_error_snapshot *snapshot){
+  sqlite3_mutex_enter(db->mutex);
+  db->errCode = snapshot->errCode;
+  db->errByteOffset = snapshot->errByteOffset;
+  if( snapshot->pErr ){
+    if( db->pErr || (db->pErr = sqlite3ValueNew(db))!=0 ){
+      (void)sqlite3VdbeMemCopy((Mem*)db->pErr, (Mem*)snapshot->pErr);
+    }
+    sqlite3_value_free(snapshot->pErr);
+    snapshot->pErr = 0;
+  }else if( db->pErr ){
+    sqlite3ValueSetNull(db->pErr);
+  }
+  sqlite3_mutex_leave(db->mutex);
+}
 
