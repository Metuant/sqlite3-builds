#!/usr/bin/with-contenv bash
# shellcheck shell=bash
# shellcheck source=/dev/null
set -u
phase_name="02-verify"
. /opt/sqlite3-lsio-mod/lib/logging.sh
. /opt/sqlite3-lsio-mod/lib/sha.sh
. /opt/sqlite3-lsio-mod/lib/arch.sh
. /opt/sqlite3-lsio-mod/lib/manifest-parser.sh
. /opt/sqlite3-lsio-mod/lib/selector.sh
sqlite3_mod_init_logging
baked_pins="/opt/sqlite3-lsio-mod/baked-pins.txt"
if [ ! -f "$baked_pins" ]; then log_fatal "mod=emby phase=${phase_name} event=missing-baked-pins"; fi
selected_arch="$(resolve_arch)" || { log_warn "mod=emby phase=${phase_name} event=unsupported-arch machine=$(uname -m)"; exit 0; }
server_id="$(select_supported_server "emby" "$selected_arch" "$baked_pins")"
[ -n "$server_id" ] || exit 0
if unsupported_row="$(selected_unsupported_row "emby" "$selected_arch" "$baked_pins" "$server_id")"; then
  IFS='|' read -r unsupported_compat_group unsupported_reason <<< "$unsupported_row"
  log_warn "mod=emby phase=${phase_name} event=unsupported-server arch=${selected_arch} server_id=${server_id} compat_group=${unsupported_compat_group} reason=${unsupported_reason}"
  exit 0
fi
artifact_row="$(selected_artifact_row "emby" "$selected_arch" "$baked_pins" "$server_id")" || log_fatal "mod=emby phase=${phase_name} event=missing-artifact-row arch=${selected_arch} server_id=${server_id}"
IFS='|' read -r compat_group artifact_relpath target_path artifact_sha256 <<< "$artifact_row"
[ -n "$compat_group" ] || log_fatal "mod=emby phase=${phase_name} event=invalid-artifact-row arch=${selected_arch} server_id=${server_id}"
[ -n "$artifact_relpath" ] || log_fatal "mod=emby phase=${phase_name} event=invalid-artifact-row arch=${selected_arch} server_id=${server_id}"
[ -n "$target_path" ] || log_fatal "mod=emby phase=${phase_name} event=invalid-artifact-row arch=${selected_arch} server_id=${server_id}"
[ -n "$artifact_sha256" ] || log_fatal "mod=emby phase=${phase_name} event=invalid-artifact-row arch=${selected_arch} server_id=${server_id}"
artifact="/opt/sqlite3-lsio-mod/${artifact_relpath}"
[ -f "$artifact" ] || log_fatal "mod=emby phase=${phase_name} event=missing-artifact path=${artifact}"
actual="$(sha256_of "$artifact")"
[ "$actual" = "$artifact_sha256" ] || log_fatal "mod=emby phase=${phase_name} event=baked-sha-mismatch expected=${artifact_sha256} actual=${actual}"
log_info "mod=emby phase=${phase_name} event=verified arch=${selected_arch} server_id=${server_id} compat_group=${compat_group} target_path=${target_path}"
