# Path to the generic tuned sqlite3 CLI used for copies, probes, and generic timings.
SQLITE_BIN=/path/to/sqlite3
# Writable directory where canary database copies and run outputs are created.
SCRATCH_ROOT=/path/to/writable/canary-scratch
# Path to the read-only source Emby library database for canary copies.
EMBY_ORIG=/path/to/emby.library.db
# Timed Emby iterations per baseline/candidate arm; use 3 or more.
EMBY_ITERATIONS=5
# Name of the Emby latest-episode candidate index to check and optionally force.
EMBY_LATEST_INDEX=idx_example_emby_latest
# Dummy Emby user id for A-shape01 templates.
CANARY_EMBY_A_SHAPE01_USER_ID=1001
# Dummy comma-separated ancestor ids for A-shape01 templates.
CANARY_EMBY_A_SHAPE01_ANCESTORS=101,102,103
# Expected ordered row count for A-shape01 identity.
CANARY_EMBY_A_SHAPE01_EXPECTED_ROWS=12
# Dummy Emby user id for A-shape04 templates.
CANARY_EMBY_A_SHAPE04_USER_ID=1002
# Dummy comma-separated ancestor ids for A-shape04 templates.
CANARY_EMBY_A_SHAPE04_ANCESTORS=201,202,203
# Expected ordered row count for A-shape04 identity.
CANARY_EMBY_A_SHAPE04_EXPECTED_ROWS=1
# Static capture template filename for the empty C-shape case.
CANARY_EMBY_C_EMPTY_CAPTURE_FILE=c-empty.sql
# Opaque capture identifier for the empty C-shape case.
CANARY_EMBY_C_EMPTY_CAPTURE_HASH=example-empty-hash
# Dummy Emby user id for the empty C-shape case.
CANARY_EMBY_C_EMPTY_USER_ID=1003
# Dummy comma-separated ancestor ids for the empty C-shape case.
CANARY_EMBY_C_EMPTY_ANCESTORS=301,302,303
# Expected grouped identity count for the empty C-shape case.
CANARY_EMBY_C_EMPTY_EXPECTED_GROUPS=0
# Static capture template filename for the two-group C-shape case.
CANARY_EMBY_C_TWO_GROUP_CAPTURE_FILE=c-two-group.sql
# Opaque capture identifier for the two-group C-shape case.
CANARY_EMBY_C_TWO_GROUP_CAPTURE_HASH=example-two-group-hash
# Dummy Emby user id for the two-group C-shape case.
CANARY_EMBY_C_TWO_GROUP_USER_ID=1004
# Dummy comma-separated ancestor ids for the two-group C-shape case.
CANARY_EMBY_C_TWO_GROUP_ANCESTORS=401,402,403
# Expected grouped identity count for the two-group C-shape case.
CANARY_EMBY_C_TWO_GROUP_EXPECTED_GROUPS=2
# Static capture template filename for the large-group C-shape case.
CANARY_EMBY_C_LARGE_GROUP_CAPTURE_FILE=c-large-group.sql
# Opaque capture identifier for the large-group C-shape case.
CANARY_EMBY_C_LARGE_GROUP_CAPTURE_HASH=example-large-group-hash
# Dummy Emby user id for the large-group C-shape case.
CANARY_EMBY_C_LARGE_GROUP_USER_ID=1005
# Dummy comma-separated ancestor ids for the large-group C-shape case.
CANARY_EMBY_C_LARGE_GROUP_ANCESTORS=501,502,503
# Expected grouped identity count for the large-group C-shape case.
CANARY_EMBY_C_LARGE_GROUP_EXPECTED_GROUPS=10
# Dummy Emby user id for the D latest-episode shape.
CANARY_EMBY_D_EP_LATEST_USER_ID=1006
# Dummy comma-separated ancestor ids for the D latest-episode shape.
CANARY_EMBY_D_EP_LATEST_ANCESTORS=601,602,603
# Expected distinct-id policy for D latest-episode identity.
CANARY_EMBY_D_EP_LATEST_EXPECTED_DISTINCT_IDS=nonempty
# Path to the Plex SQLite CLI used for Plex-specific identity checks.
PLEX_SQLITE_BIN=/path/to/plex-sqlite
# Path to the read-only source Plex library database for canary copies.
PLEX_ORIG=/path/to/plex.library.db
# Timed Plex iterations per baseline/candidate arm; use 3 or more.
PLEX_TIMED_ITERS=5
# Dummy Plex library section id for tag-membership checks.
PLEX_TAG_SECTION_ID=10
# Dummy Plex tag id for tag-membership checks.
PLEX_TAG_ID=2001
# Name of the Plex taggings candidate index to verify in EQP output.
PLEX_TAG_INDEX=idx_example_taggings_tag_id_metadata_item_id
# Dummy Plex section id for On Deck checks.
PLEX_ONDECK_SECTION_ID=20
# Dummy Plex account id for On Deck checks.
PLEX_ONDECK_ACCOUNT_ID=3001
# Name of the Plex On Deck candidate index to create and verify.
PLEX_ONDECK_INDEX=idx_example_metadata_item_views_account_grandparent_guid
# Dummy comma-separated Plex metadata id list for On Deck checks.
PLEX_ONDECK_IDLIST=7001,7002,7003
