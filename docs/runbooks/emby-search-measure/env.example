# Path to the tuned sqlite3 CLI used for Emby search-measure host measurements.
SQLITE_BIN=/path/to/sqlite3
# Path to the read-only Emby library database copy used by the harness.
EMBY_DB=/path/to/emby.library.db
# Writable directory where run outputs are created.
SCRATCH_ROOT=/path/to/writable/emby-search-measure-scratch
# Timed iterations per baseline/candidate arm; use 3 or more.
ITERS=4
# Dummy Emby user id used by the source query templates.
EMBY_USER_ID=1001
# Dummy comma-separated Emby ancestor id list used by the query templates.
EMBY_ANCESTORS=101,102,103
# Dummy FTS MATCH literal for the first OR residual case.
MATCH_CASE1_OR='("alpha"*) OR ("beta"*)'
# Dummy FTS MATCH literal for the first AND control case.
MATCH_CASE1_AND='("alpha"*) AND ("beta"*)'
# Dummy FTS MATCH literal for the second OR residual case.
MATCH_CASE2_OR='("gamma"*) OR ("delta"*)'
# Dummy FTS MATCH literal for the second AND control case.
MATCH_CASE2_AND='("gamma"*) AND ("delta"*)'
# Dummy FTS MATCH literal for optional phrase timing.
MATCH_PHRASE='"alpha beta"'
# Dummy FTS MATCH literal for optional phrase-prefix timing.
MATCH_PHRASE_PREFIX='"alpha beta"*'
# Dummy FTS MATCH literal for an optional additional AND control.
MATCH_CASE3_AND='("epsilon"*) AND ("zeta"*)'
