# Host-local paths. Copy to ignored ./env and replace every placeholder.
SQLITE_BIN=/path/to/runtime-matching/sqlite3
PLEX_DB_SOURCE=/path/to/offline/plex.database.copy
EMBY_DB_SOURCE=/path/to/offline/emby.library.copy
SCRATCH_ROOT=/path/to/one/query-measure-scratch-subdirectory
# Optional when the tool directory is copied outside this repository.
# REPO_ROOT=/path/to/read-only/sqlite3-builds-checkout

# Shared caps and policy.
TIMEOUT_S=10
SETUP_TIMEOUT_S=300
TIMED_ITERS=5
DISK_MARGIN_BYTES=1073741824
CANARY_MAX_RATIO=1.25
ANALYZE_COPY=0
KEEP_OUTPUTS=0

# Plex On-Deck literal derivation.
IDLIST_SIZE=50
THRESHOLD_RANK=100

# Emby database-derived cell sizes.
DASHBOARD_ANCESTOR_SIZE=12
FANOUT_ANCESTOR_SIZE=20

# Set to 1 only to create the three shipped dashboard indexes on the throwaway copy.
PREPARE_DASHBOARD_INDEXES=0
PREPARE_PLEX_INDEXES=0

# Optional case narrowing examples. Leave unset for full family inventories.
# CASES='episodes-latest'
# SEARCH_CANDIDATES='COMBINED B8'
# SEARCH_VARIANTS='type presentation'
# SEARCH_MATCH_CASES='case1_or case1_and case2_or case2_and'
